# =========================================================================
# Configuration locale Django — copier ce fichier en `.env` et remplir
# Le `.env` ne doit JAMAIS etre commit (cf. .gitignore).
# =========================================================================

# --- Django ---
# Generer une nouvelle cle avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi-genere-une-cle-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de donnees ---
# Pour dev local en SQLite : laisser DB_ENGINE=django.db.backends.sqlite3 et DB_NAME=db.sqlite3
# Pour PostgreSQL :
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Email (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- Site ---
SITE_DOMAIN=http://127.0.0.1:8000

# --- AWS (optionnel, si stockage S3) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
